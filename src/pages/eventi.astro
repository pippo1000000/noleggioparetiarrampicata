---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import { getCollection } from 'astro:content';
import { getImage, Image } from 'astro:assets';
import heroImage from '../assets/hero-eventi.jpg';

const events = await getCollection('eventi');
const sortedEvents = events.sort((a, b) => {
  const dateA = new Date(a.data.sortDate).getTime();
  const dateB = new Date(b.data.sortDate).getTime();
  return dateB - dateA;
});

const optimizedHero = await getImage({ src: heroImage, format: 'webp', width: 1920 });

export const prerender = true;
---

<Layout title="I Nostri Eventi | Noleggio Strutture">
  <Navbar />
  
  <main class="events-page">
    <header class="page-header">
      <div class="container">
        <h1>I NOSTRI <span class="highlight">EVENTI</span></h1>
        <p class="subtitle">Scopri i progetti che abbiamo realizzato e le sfide che abbiamo vinto.</p>
      </div>
    </header>

    <section class="events-grid-section">
      <div class="container">
        <div class="events-grid">
          {sortedEvents.map((event) => (
            <div class="event-card-big">
              <div class="image-area">
                <Image src={event.data.image} alt={event.data.title} width={800} height={600} format="webp" />
                <div class="date-overlay">
                  {String(event.data.date)}
                </div>
              </div>
              <div class="info-area">
                <span class="location-tag">{event.data.location}</span>
                <h2>{event.data.title}</h2>
                <p>{event.data.description}</p>
                <div class="divider"></div>
                {event.data.videoUrl && (
                  <button class="video-btn" data-video-url={event.data.videoUrl}>
                    <svg viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
                    Guarda il video dell'evento
                  </button>
                )}
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <dialog id="video-modal" class="video-modal">
      <div class="modal-content">
        <button id="close-video-modal" class="close-modal">&times;</button>
        <div class="video-container">
          <iframe 
            id="video-frame"
            width="100%" 
            height="100%" 
            frameborder="0" 
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" 
            allowfullscreen
          ></iframe>
        </div>
      </div>
    </dialog>
  </main>
</Layout>

<style define:vars={{ heroBg: `url(${optimizedHero.src})` }}>
  .events-page {
    background-color: var(--color-bg-secondary);
    min-height: 100vh;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 30px;
  }

  .page-header {
    height: 70vh;
    min-height: 600px;
    background-image: var(--heroBg);
    background-size: cover;
    background-position: center;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    color: white;
    position: relative;
    padding: 0;
  }

  .page-header::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(rgba(0, 0, 0, 0.45), rgba(0, 0, 0, 0.65));
    z-index: 1;
  }

  .page-header .container {
    position: relative;
    z-index: 2;
  }

  .page-header h1 {
    font-size: clamp(3.5rem, 12vw, 7.5rem);
    font-weight: 950;
    margin-bottom: 20px;
    color: white;
    line-height: 0.9;
    letter-spacing: -0.03em;
    text-transform: uppercase;
  }

  .page-header .highlight {
    color: white;
  }

  .highlight {
    color: var(--color-primary);
  }

  .subtitle {
    font-size: 1.5rem;
    color: white;
    opacity: 0.9;
    max-width: 700px;
    margin: 0 auto;
  }

  .events-grid-section {
    padding: 100px 0;
  }

  .events-grid {
    display: flex;
    flex-direction: column;
    gap: 80px;
  }

  .event-card-big {
    display: grid;
    grid-template-columns: 1fr 1fr;
    background: white;
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-lg);
    align-items: center;
  }

  .image-area {
    position: relative;
    height: 100%;
    min-height: 400px;
  }

  .image-area img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .date-overlay {
    position: absolute;
    bottom: 20px;
    left: 20px;
    background: rgba(0,0,0,0.7);
    backdrop-filter: blur(10px);
    color: white;
    padding: 10px 20px;
    border-radius: var(--radius-sm);
    font-weight: 600;
  }

  .info-area {
    padding: 60px;
  }

  .location-tag {
    color: var(--color-primary);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-size: 0.9rem;
    margin-bottom: 15px;
    display: block;
  }

  .info-area h2 {
    font-size: 2.5rem;
    font-weight: 900;
    margin-bottom: 20px;
    color: var(--color-secondary);
  }

  .info-area p {
    font-size: 1.25rem;
    line-height: 1.6;
    color: var(--color-text-body);
    margin-bottom: 30px;
  }

  .divider {
    height: 4px;
    width: 60px;
    background: var(--color-primary);
  }

  @media (max-width: 1024px) {
    .event-card-big {
      grid-template-columns: 1fr;
    }
    .image-area {
      min-height: 350px;
    }
    .info-area {
      padding: 40px 30px;
    }
  }

  /* Premium Video Button */
  .video-btn {
    outline: none;
    border: none;
    display: inline-flex;
    align-items: center;
    gap: 15px;
    background: var(--color-secondary);
    color: white;
    padding: 18px 35px;
    border-radius: var(--radius-md);
    font-weight: 800;
    font-size: 1rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    cursor: pointer;
    transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    margin-top: 35px;
    box-shadow: 0 10px 25px rgba(0, 0, 0, 0.15);
    position: relative;
    overflow: hidden;
  }

  .video-btn::before {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(
      90deg,
      transparent,
      rgba(255, 255, 255, 0.1),
      transparent
    );
    transition: 0.5s;
  }

  .video-btn:hover::before {
    left: 100%;
  }

  .video-btn svg {
    width: 32px;
    height: 32px;
    fill: var(--color-primary);
    transition: transform 0.3s ease;
  }

  .video-btn:hover {
    transform: translateY(-5px) scale(1.02);
    box-shadow: 0 15px 35px rgba(0, 0, 0, 0.25);
    background: #1a1a1a;
  }

  .video-btn:hover svg {
    transform: scale(1.2);
  }

  /* Premium Video Modal Overlay */
  .video-modal {
    width: 100vw;
    height: 100vh;
    max-width: 100vw;
    max-height: 100vh;
    padding: 0;
    border: none;
    background: transparent;
    position: fixed;
    inset: 0;
    z-index: 9999;
  }

  .video-modal::backdrop {
    background: rgba(0, 0, 0, 0.92);
    backdrop-filter: blur(25px);
  }

  .modal-content {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 5vh 5vw;
    position: relative;
  }

  .video-container {
    width: 100%;
    height: 100%;
    max-width: 1600px;
    max-height: 90vh;
    background: black;
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: 0 0 100px rgba(0, 0, 0, 0.8);
    position: relative;
    border: 1px solid rgba(255, 255, 255, 0.1);
  }

  .video-container iframe {
    width: 100%;
    height: 100%;
    border: none;
  }

  .close-modal {
    position: absolute;
    top: 30px;
    right: 30px;
    background: white;
    color: var(--color-secondary);
    border: none;
    width: 55px;
    height: 55px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2rem;
    cursor: pointer;
    transition: all 0.3s ease;
    z-index: 10001;
    box-shadow: 0 10px 20px rgba(0,0,0,0.3);
  }

  .close-modal:hover {
    transform: rotate(90deg) scale(1.1);
    background: var(--color-primary);
    color: white;
  }

  @media (max-width: 768px) {
    .modal-content {
      padding: 10px;
    }
    .video-container {
      height: auto;
      aspect-ratio: 16 / 9;
    }
    .close-modal {
      top: 15px;
      right: 15px;
      width: 40px;
      height: 40px;
      font-size: 1.5rem;
    }
    .video-btn {
      width: 100%;
      padding: 18px 25px;
      font-size: 0.95rem;
      justify-content: center;
      gap: 12px;
    }
    .video-btn svg {
      width: 28px;
      height: 28px;
    }
  }
</style>

<script>
  function getYoutubeId(url) {
    const regExp = /^.*(youtu.be\/|v\/|u\/\w\/|embed\/|watch\?v=|\&v=|shorts\/)([^#\&\?]*).*/;
    const match = url.match(regExp);
    return (match && match[2].length === 11) ? match[2] : null;
  }

  const modal = document.getElementById('video-modal');
  const frame = document.getElementById('video-frame');
  const closeBtn = document.getElementById('close-video-modal');
  const videoBtns = document.querySelectorAll('.video-btn');

  videoBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const url = btn.getAttribute('data-video-url');
      if (url) {
        const id = getYoutubeId(url);
        if (id) {
          frame.src = `https://www.youtube.com/embed/${id}?autoplay=1`;
          modal.showModal();
        }
      }
    });
  });

  closeBtn?.addEventListener('click', () => {
    modal.close();
    frame.src = '';
  });

  modal?.addEventListener('click', (e) => {
    if (e.target === modal) {
      modal.close();
      frame.src = '';
    }
  });
</script>
