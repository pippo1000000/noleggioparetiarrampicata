---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Button from '../components/Button.astro';
---

<Layout title="Contattaci | Noleggio Strutture">
  <Navbar />
  
  <main class="contact-page">
    <header class="page-header">
      <div class="container">
        <h1>CONTATTI</h1>
        <p class="subtitle">Hai domande o vuoi un preventivo? Siamo a tua disposizione.</p>
      </div>
    </header>

    <section class="contact-content">
      <div class="container contact-grid">
        <div class="contact-form-container">
          <h2>Inviaci un <span class="highlight">messaggio</span></h2>
          <form class="contact-form">
            <div class="form-group">
              <label for="name">Nome</label>
              <input type="text" id="name" name="name" placeholder="Inserisci il tuo nome" required />
            </div>
            
            <div class="form-group">
              <label for="email">Email</label>
              <input type="email" id="email" name="email" placeholder="esempio@email.it" required />
            </div>


            <div class="form-group">
              <label for="message">Messaggio</label>
              <textarea id="message" name="message" rows="5" placeholder="Come possiamo aiutarti?" required></textarea>
            </div>

            <Button variant="primary" size="lg" class="submit-btn" type="submit">Invia Messaggio</Button>
          </form>
        </div>

        <div class="contact-info">
          <h2>Informazioni di <span class="highlight">contatto</span></h2>
          <div class="map-container">
            <iframe 
              src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2969.654246110986!2d12.492230876615555!3d41.89021017124039!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x132f61b65357fc81%3A0x2350e910bd2a33f4!2sColosseo!5e0!3m2!1sit!2sit!4v1711380000000!5m2!1sit!2sit" 
              width="100%" 
              height="250" 
              style="border:0;" 
              allowfullscreen="" 
              loading="lazy" 
              referrerpolicy="no-referrer-when-downgrade">
            </iframe>
          </div>
          <div class="info-items">
            <div class="info-item">
              <div class="icon">📞</div>
              <div class="details">
                <h3>Telefono</h3>
                <p>+39 012 345 6789</p>
              </div>
            </div>
            <div class="info-item">
              <div class="icon">✉️</div>
              <div class="details">
                <h3>Email</h3>
                <p>info@clbenj.it</p>
              </div>
            </div>
            <div class="info-item">
              <div class="icon">📍</div>
              <div class="details">
                <h3>Sede</h3>
                <p>Via delle Rocce, 12, Roma (RM)</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Workless Collective Section -->
    <section class="workless-section">
      <div class="container text-center">
        <div class="workless-card">
          <h2>Scopri di più su <span class="highlight">Workless Collective</span></h2>
          <p>Siamo parte di un ecosistema creativo che ridefinisce l'eccellenza negli eventi e nella comunicazione.</p>
          <div class="cta-wrapper">
            <Button href="https://www.worklesscollective.com" variant="secondary" size="lg" target="_blank" rel="noopener noreferrer">
              Visita il sito ufficiale
            </Button>
          </div>
        </div>
      </div>
    </section>
  </main>
</Layout>

<style>
  .contact-page {
    background-color: var(--color-bg-primary);
  }

  .page-header {
    height: 70vh;
    min-height: 600px;
    background-image: url('/assets/contatti_hero_bg.png');
    background-size: cover;
    background-position: center;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    color: white;
    position: relative;
    padding: 0;
  }

  .page-header::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(rgba(0, 0, 0, 0.45), rgba(0, 0, 0, 0.65));
    z-index: 1;
  }

  .page-header .container {
    position: relative;
    z-index: 2;
  }

  .page-header h1 {
    font-size: clamp(3.5rem, 12vw, 7.5rem);
    font-weight: 950;
    margin-bottom: 20px;
    color: white;
    line-height: 0.9;
    letter-spacing: -0.03em;
    text-transform: uppercase;
  }

  .highlight {
    color: var(--color-primary);
  }

  .subtitle {
    font-size: 1.5rem;
    color: white;
    opacity: 0.9;
    max-width: 700px;
    margin: 0 auto;
  }

  .contact-content {
    padding: 100px 0;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    gap: 80px;
  }

  @media (max-width: 1023px) {
    .contact-grid {
      grid-template-columns: 1fr;
      gap: 60px;
    }
  }

  .contact-form-container h2,
  .contact-info h2 {
    font-size: 2.5rem;
    font-weight: 900;
    margin-bottom: 40px;
    color: var(--color-secondary);
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 25px;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .form-group label {
    font-weight: 700;
    color: var(--color-secondary);
    font-size: 0.9rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .form-group input,
  .form-group textarea {
    padding: 15px 20px;
    border: 2px solid var(--color-border);
    border-radius: var(--radius-md);
    font-family: inherit;
    font-size: 1rem;
    transition: border-color 0.3s ease;
  }

  .form-group input:focus,
  .form-group textarea:focus {
    outline: none;
    border-color: var(--color-primary);
  }

  .submit-btn {
    width: 100%;
    margin-top: 10px;
  }

  .info-items {
    display: flex;
    flex-direction: column;
    gap: 40px;
  }

  .info-item {
    display: flex;
    gap: 20px;
    align-items: flex-start;
  }

  .info-item .icon {
    font-size: 2rem;
    background: var(--color-bg-secondary);
    width: 60px;
    height: 60px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: var(--radius-md);
    flex-shrink: 0;
  }

  .info-item h3 {
    margin-bottom: 5px;
    font-size: 1.25rem;
    color: var(--color-secondary);
  }

  .info-item p {
    color: var(--color-text-body);
    font-size: 1.1rem;
  }

  .map-container {
    width: 100%;
    height: 250px;
    background: #eee;
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-sm);
    border: 1px solid var(--color-border);
    margin-bottom: 30px;
  }

  /* Workless Collective Section */
  .workless-section {
    padding: 100px 0 150px 0;
    background: linear-gradient(to bottom, var(--color-bg-primary), var(--color-bg-secondary));
  }

  .workless-card {
    background: white;
    padding: 60px 40px;
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-lg);
    border: 1px solid var(--color-border);
    max-width: 800px;
    margin: 0 auto;
    position: relative;
    overflow: hidden;
  }

  .workless-card h2 {
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    font-weight: 950;
    margin-bottom: 1.5rem;
    color: var(--color-secondary);
  }

  .workless-card p {
    font-size: 1.2rem;
    color: var(--color-text-subtle);
    margin-bottom: 2.5rem;
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
  }

  .cta-wrapper {
    display: flex;
    justify-content: center;
  }

  .text-center { text-align: center; }
</style>
