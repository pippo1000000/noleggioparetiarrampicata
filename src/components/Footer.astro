---
const currentYear = new Date().getFullYear();
---

<footer class="footer">
  <div class="container footer-grid">
    <!-- Brand Section -->
    <div class="footer-brand">
      <div class="logo">
        <span>noleggioparetiarrampicata.it</span>
      </div>
      <p class="brand-description">
        Esperti nel noleggio di strutture per eventi indimenticabili. Dalle pareti di arrampicata ai tendoni eleganti, portiamo l'avventura e il comfort ovunque tu sia.
      </p>
      <div class="footer-socials">
        <a href="https://www.instagram.com/crash_fest_/" target="_blank" rel="noopener noreferrer" aria-label="Instagram">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>
        </a>
        <a href="https://www.youtube.com/@worklesscollective" target="_blank" rel="noopener noreferrer" aria-label="YouTube">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22.54 6.42a2.78 2.78 0 0 0-1.94-2C18.88 4 12 4 12 4s-6.88 0-8.6.42a2.78 2.78 0 0 0-1.94 2C1 8.11 1 12 1 12s0 3.89.46 5.58a2.78 2.78 0 0 0 1.94 2c1.72.42 8.6.42 8.6.42s6.88 0 8.6-.42a2.78 2.78 0 0 0 1.94-2C23 15.89 23 12 23 12s0-3.89-.46-5.58z"></path><polygon points="9.75 15.02 15.5 12 9.75 8.98 9.75 15.02"></polygon></svg>
        </a>
        <a href="https://www.linkedin.com/company/workless-collective/" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path><rect x="2" y="9" width="4" height="12"></rect><circle cx="4" cy="4" r="2"></circle></svg>
        </a>
      </div>
    </div>

    <!-- Quick Links -->
    <div class="footer-links">
      <h4>Link Rapidi</h4>
      <ul>
        <li><a href="/">Home</a></li>
        <li><a href="/servizi">Servizi</a></li>
        <li><a href="/eventi">Eventi realizzati</a></li>
        <li><a href="/contatti">Contatti</a></li>
        <li><a href="/privacy-policy">Privacy Policy</a></li>
      </ul>
    </div>

    <!-- Contact Info -->
    <div class="footer-contact">
      <h4>Contatti</h4>
      <ul>

        <li>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          <a href="mailto:info@noleggioparetiarrampicata.it">info@noleggioparetiarrampicata.it</a>
        </li>
        <li>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
          <span><a href="https://www.google.com/maps/dir/?api=1&destination=Via+Roma+56+Rubano+PD" target="_blank" rel="noopener noreferrer">Via Roma 56, Rubano (PD)</a></span>
        </li>
      </ul>
    </div>
  </div>

  <div class="footer-bottom">
    <div class="container">
      <p>&copy; {currentYear} noleggioparetiarrampicata.it. Tutti i diritti riservati.</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background-color: var(--color-secondary);
    color: white;
    padding: 100px 0 0 0;
    margin-top: 150px;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1.5fr;
    gap: 80px;
    margin-bottom: 80px;
  }

  .footer-brand .logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-weight: 800;
    font-size: 1.8rem;
    color: white;
    margin-bottom: 1.5rem;
    letter-spacing: 0.05em;
  }

  .footer-brand .icon {
    width: 36px;
    height: 36px;
    color: var(--color-primary);
  }

  .brand-description {
    color: rgba(255, 255, 255, 0.7);
    line-height: 1.8;
    margin-bottom: 2rem;
  }

  .footer-socials {
    display: flex;
    gap: 15px;
  }

  .footer-socials a {
    width: 40px;
    height: 40px;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    transition: all 0.3s ease;
  }

  .footer-socials a:hover {
    background: var(--color-primary);
    border-color: var(--color-primary);
    transform: translateY(-3px);
    color: white;
  }

  .footer-socials svg {
    width: 18px;
    height: 18px;
  }

  .footer h4 {
    color: white;
    font-size: 1.25rem;
    margin-bottom: 2rem;
    position: relative;
  }

  .footer h4::after {
    content: '';
    position: absolute;
    bottom: -10px;
    left: 0;
    width: 40px;
    height: 3px;
    background-color: var(--color-primary);
  }

  .footer ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .footer-links li {
    margin-bottom: 1rem;
  }

  .footer-links a {
    color: rgba(255, 255, 255, 0.7);
    transition: color 0.3s ease, padding-left 0.3s ease;
    display: inline-block;
  }

  .footer-links a:hover {
    color: var(--color-primary);
    padding-left: 5px;
  }

  .footer-contact li {
    display: flex;
    align-items: flex-start;
    gap: 15px;
    margin-bottom: 1.5rem;
    color: rgba(255, 255, 255, 0.7);
  }

  .footer-contact svg {
    width: 20px;
    height: 20px;
    color: var(--color-primary);
    flex-shrink: 0;
    margin-top: 5px;
  }

  .footer-contact a {
    color: inherit;
  }

  .footer-contact a:hover {
    color: var(--color-primary);
  }

  .footer-bottom {
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    padding: 30px 0;
    text-align: center;
    color: rgba(255, 255, 255, 0.5);
    font-size: 0.9rem;
  }

  @media (max-width: 1024px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
      gap: 50px;
    }
    .footer-brand {
      grid-column: span 2;
    }
  }

  @media (max-width: 767px) {
    .footer {
      padding: 60px 0 0 0;
    }
    .footer-grid {
      grid-template-columns: 1fr;
      gap: 40px;
    }
    .footer-brand {
      grid-column: span 1;
    }
    .footer-brand .logo {
      font-size: clamp(0.7rem, 4.8vw, 1.2rem);
      white-space: nowrap;
      letter-spacing: 0;
    }
    .footer-bottom .container {
      padding: 0 20px;
    }
    .footer-bottom p {
      font-size: 0.8rem;
    }
  }
</style>
