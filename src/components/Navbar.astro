---
import Button from './Button.astro';
---

<nav class="navbar">
  <div class="container">
    <!-- Logo -->
    <div class="logo">
      <a href="/">
        <span>noleggioparetiarrampicata.it</span>
      </a>
    </div>

    <!-- Center Menu -->
    <div class="menu-wrapper">
      <ul class="nav-menu">
        <li><a href="/">Home</a></li>
        <li><a href="/servizi">Servizi</a></li>
        <li><a href="/eventi">Eventi realizzati</a></li>
        <li><a href="/contatti">Contatti</a></li>
      </ul>
    </div>

    <!-- CTA -->
    <div class="cta">
      <Button href="/contatti" variant="primary" size="sm" class="nav-btn">Richiedi Info</Button>
    </div>
  </div>
</nav>

<script>
  const nav = document.querySelector('.navbar');
  if (nav) {
    window.addEventListener('scroll', () => {
      if (window.scrollY > 20) {
        nav.classList.add('scrolled');
      } else {
        nav.classList.remove('scrolled');
      }
    });
  }
</script>

<style>
  .navbar {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 100;
    padding: 1.5rem 0;
    display: flex;
    justify-content: center;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .navbar.scrolled {
    background: rgba(255, 255, 255, 0.9);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    padding: 0.8rem 0;
    box-shadow: 0 4px 30px rgba(0, 0, 0, 0.1);
    border-bottom: 1px solid rgba(255, 255, 255, 0.3);
  }

  .container {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    width: 95%; /* Slightly wider for longer logo */
    max-width: 1400px;
    margin: 0 auto;
  }

  .logo a {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-weight: 800;
    font-size: 1.1rem;
    color: white;
    text-decoration: none;
    letter-spacing: 0;
    transition: color 0.3s ease;
    white-space: nowrap;
  }

  .navbar.scrolled .logo a {
    color: var(--color-secondary);
  }

  .logo svg {
    width: 32px;
    height: 32px;
    color: white;
    transition: color 0.3s ease;
  }

  .navbar.scrolled .logo svg {
    color: var(--color-primary);
  }

  .logo {
    justify-self: start;
  }

  .menu-wrapper {
    justify-self: center;
    background: rgba(255, 255, 255, 0.1);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, 0.2);
    padding: 0.5rem 2rem;
    border-radius: var(--radius-pill);
    transition: all 0.3s ease;
  }

  .navbar.scrolled .menu-wrapper {
    background: transparent;
    border-color: transparent;
    backdrop-filter: none;
    -webkit-backdrop-filter: none;
  }

  .nav-menu {
    list-style: none;
    display: flex;
    gap: 2rem;
    margin: 0;
    padding: 0;
  }

  .nav-menu a {
    color: rgba(255, 255, 255, 0.9);
    text-decoration: none;
    font-size: 0.9rem;
    font-weight: 500;
    transition: all 0.3s ease;
  }

  .navbar.scrolled .nav-menu a {
    color: var(--color-secondary);
  }

  .nav-menu a:hover {
    color: white;
  }

  .navbar.scrolled .nav-menu a:hover {
    color: var(--color-primary);
  }

  .cta {
    justify-self: end;
  }

  .nav-btn {
    background-color: var(--color-primary) !important;
    border-radius: var(--radius-pill) !important;
  }

  @media (max-width: 768px) {
    .container {
      display: flex;
      justify-content: space-between;
      gap: 10px;
    }
    .logo a {
      font-size: clamp(0.7rem, 4vw, 0.95rem);
    }
    .menu-wrapper {
      display: none;
    }
    .cta {
      flex-shrink: 0;
    }
    .navbar {
      padding: 1rem 0;
    }
  }
</style>
