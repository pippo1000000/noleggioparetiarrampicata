---
import { getCollection } from 'astro:content';

const events = await getCollection('eventi');
// Sort by date descending, with safety check
const allSortedEvents = events.sort((a, b) => {
  const dateA = new Date(a.data.sortDate).getTime();
  const dateB = new Date(b.data.sortDate).getTime();
  return dateB - dateA;
});

// Take only the last 3 events
const featuredEvents = allSortedEvents.slice(0, 3);
---

<section class="events-section">
  <div class="container">
    <div class="header">
      <h2 class="title-main">I NOSTRI <span class="highlight-blue">EVENTI</span></h2>
      <a href="/eventi" class="view-all">VEDI TUTTI GLI EVENTI →</a>
    </div>

    <!-- Events Grid Container -->
    <div class="events-grid">
      {featuredEvents.map((event) => (
        <div class="event-item">
          <div class="image-wrapper">
            <img src={event.data.image} alt={event.data.title} loading="lazy" />
          </div>
          <div class="card-content">
            <span class="location">{event.data.location}</span>
            <h3>{event.data.title}</h3>
            <p>{event.data.description}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .events-section {
    padding: 120px 0;
    background-color: var(--color-bg-primary);
    overflow: hidden;
  }

  .container {
    max-width: 1400px;
    margin: 0 auto;
    position: relative;
  }

  .header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 60px;
    gap: 30px;
  }

  .title-main {
    font-size: clamp(3rem, 7vw, 5.5rem);
    font-weight: 950;
    line-height: 0.9;
    color: var(--color-secondary);
    margin: 0;
    text-transform: uppercase;
    letter-spacing: -0.02em;
  }

  .highlight-blue {
    color: var(--color-primary);
  }

  .view-all {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--color-secondary);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding-bottom: 5px;
    border-bottom: 2px solid var(--color-primary);
    white-space: nowrap;
    transition: color 0.3s ease;
  }

  .view-all:hover {
    color: var(--color-primary);
  }

  /* Events Grid */
  .events-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 40px;
  }

  .event-item {
    background: transparent;
    border-radius: 0;
    overflow: visible;
  }

  .image-wrapper {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 10;
    overflow: hidden;
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-md);
  }

  .image-wrapper img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .card-content {
    padding: 25px 0 0 0;
  }

  .location {
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--color-primary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    display: block;
    margin-bottom: 8px;
  }

  .card-content h3 {
    font-size: 1.75rem;
    font-weight: 800;
    margin: 0 0 10px 0;
    color: var(--color-secondary);
  }

  .card-content p {
    font-size: 1.05rem;
    line-height: 1.5;
    color: var(--color-text-body);
    margin: 0;
    opacity: 0.9;
  }

  @media (max-width: 1199px) {
    .events-grid {
      gap: 30px;
    }
    .card-content h3 {
      font-size: 1.5rem;
    }
  }

  @media (max-width: 1023px) {
    .header {
      flex-direction: column;
      align-items: flex-start;
      gap: 20px;
    }
    .events-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 767px) {
    .container {
      padding: 0 30px;
    }
    .events-grid {
      grid-template-columns: 1fr;
      gap: 50px;
    }
  }
</style>
