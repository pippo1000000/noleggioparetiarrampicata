---
import Button from './Button.astro';
---

<section class="hero">
  <div class="hero-bg">
    <img src="/assets/background.png" alt="Climbing wall background" class="bg-img" />
    <div class="overlay"></div>
  </div>

  <div class="container">
    <div class="text-container">
      <h1 class="hero-title">
        <span class="line">ADRENALINA</span>
        <span class="line">PER IL TUO</span>
        <span class="line">EVENTO</span>
      </h1>
      <h2 class="hero-subtitle">
        <span class="line">Una parete di arrampicata è la sfida verticale che rompe la noia.</span>
        <span class="line">Trasforma i tuoi spettatori in partecipanti attivi, al montaggio e alla sicurezza ci pensiamo noi!</span>
      </h2>
      
      <div class="hero-actions">
        <Button href="#come-funziona" variant="primary" size="lg" class="cta-main">
          Scopri come funziona <span class="icon-span">🏔️</span> 
        </Button>
      </div>
    </div>

    <!-- 3D Element: The Climber -->
    <div class="climber-wrapper">
      <img src="/assets/climber.png" alt="Climber" class="climber-img" />
    </div>
  </div>

  <!-- Stats Badge (Outside container to be at screen edge) -->
  <div class="stats-badge">
    <div class="stats-number">50+</div>
    <div class="stats-label">Eventi già<br/>realizzati</div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    height: 100vh;
    width: 100%;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    padding-top: 80px; /* Space for the fixed navbar */
  }

  .hero-bg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: -1;
  }

  .bg-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: brightness(0.8);
  }

  .overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: radial-gradient(circle at center, transparent 0%, rgba(0,0,0,0.4) 100%);
  }

  .hero > .container {
    position: relative;
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: center;
    z-index: 10;
  }

  .text-container {
    position: relative;
    z-index: 5;
    text-align: left;
    max-width: 800px;
  }

  .hero-title {
    font-size: clamp(2rem, 9vw, 9rem);
    line-height: 0.85;
    font-weight: 950;
    text-transform: uppercase;
    color: #FFFFFF;
    margin: 0;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    letter-spacing: -0.05em;
    font-family: 'Inter', sans-serif;
  }

  .hero-title .line {
    display: block;
  }

  .hero-subtitle {
    font-size: 1.5rem;
    margin-top: 1.5rem;
    opacity: 0.9;
    font-weight: 400;
    color: #FFFFFF;
  }

  .hero-actions {
    margin-top: 3rem;
  }

  .cta-main {
    background-color: #1a1a1a !important;
    border: 1px solid rgba(255,255,255,0.2) !important;
    font-size: 1.25rem !important;
    padding: 1rem 2.5rem !important;
  }

  .icon-span {
    margin: 0 0.5rem;
    font-size: 1.2rem;
  }

  /* 3D Climber Effect */
  .climber-wrapper {
    position: absolute;
    bottom: 0;
    left: 80%; /* Moved further right to avoid text overlap */
    transform: translateX(-50%);
    height: 110%;
    width: auto;
    z-index: 6;
    pointer-events: none;
    display: flex;
    align-items: flex-end;
    justify-content: center;
  }

  .climber-img {
    height: 100%;
    width: auto;
    object-fit: contain;
    filter: drop-shadow(0 20px 50px rgba(0,0,0,0.5));
  }

  /* Stats Badge */
  .stats-badge {
    position: absolute;
    bottom: 10%;
    right: 0;
    background: var(--color-primary);
    padding: 1.5rem 2rem;
    border-radius: var(--radius-lg) 0 0 var(--radius-lg);
    display: flex;
    align-items: center;
    gap: 1rem;
    box-shadow: var(--shadow-lg);
  }

  .stats-number {
    font-size: 3rem;
    font-weight: 800;
    line-height: 1;
  }

  .stats-label {
    font-size: 0.9rem;
    line-height: 1.2;
    font-weight: 600;
    text-transform: uppercase;
    opacity: 0.9;
  }

  @media (max-width: 1440px) {
    .climber-wrapper {
      left: 85%;
      height: 100%;
    }
    .hero-title {
      font-size: clamp(3rem, 8vw, 7rem);
    }
  }

  @media (max-width: 1200px) {
    .climber-wrapper {
      display: none; /* Hide on smaller laptops and tablets for better readability */
    }
    .hero-title {
      font-size: clamp(3rem, 12vw, 6rem);
    }
    .text-container {
      max-width: 100%;
      text-align: center;
      padding: 0 20px;
    }
    .hero-title {
      align-items: center;
    }
  }

  @media (max-width: 768px) {
    .hero {
      height: auto;
      min-height: 100vh;
      padding-top: 120px;
      padding-bottom: 60px;
    }
    .hero-title {
      font-size: 3.5rem;
    }
    .hero-subtitle {
      font-size: 1.1rem;
    }
    .stats-badge {
      display: none;
    }
  }
</style>
